      "command": "npx",
      "args": ["-y", "@primis-core/mcp-server"]
    },
    "google-drive": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-google-drive"]
    },
    "discord": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-discord"]
    },
    "puppeteer": {
